{
    "$schema": "https://turbo.build/schema.json",
    "ui": "tui",
    "globalPassThroughEnv": [
        "CONVEX_DEPLOY_KEY",
        "CONVEX_SELF_HOSTED_URL",
        "CONVEX_SELF_HOSTED_ADMIN_KEY",
        "NODE_ENV"
    ],
    "tasks": {
        "build": {
            "dependsOn": [
                "^build"
            ],
            "inputs": [
                "$TURBO_DEFAULT$",
                ".env*"
            ],
            "env": [
                "CONVEX_DEPLOY_KEY"
            ],
            "outputs": [
                "dist/**",
                ".next/**",
                "!.next/cache/**"
            ]
        },
        "lint": {
            "dependsOn": [
                "^lint"
            ]
        },
        "dev": {
            "cache": false,
            "persistent": true
        },
        "desktop": {
            "cache": false,
            "persistent": true
        },
        "deploy": {
            "dependsOn": [
                "build"
            ]
        }
    }
}