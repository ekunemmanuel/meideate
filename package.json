{
    "name": "meideate-template",
    "private": true,
    "workspaces": [
        "apps/*",
        "packages/*"
    ],
    "scripts": {
        "build": "turbo build",
        "dev": "turbo dev",
        "lint": "turbo lint",
        "format": "prettier --write \"**/*.{ts,tsx,md}\"",
        "desktop": "turbo run desktop --filter=@meideate/desktop",
        "web": "turbo run dev --filter=@meideate/web",
        "mobile": "turbo run dev --filter=@meideate/mobile"
    },
    "devDependencies": {
        "turbo": "^2.3.4",
        "prettier": "^3.4.2"
    },
    "packageManager": "bun@1.3.5"
}