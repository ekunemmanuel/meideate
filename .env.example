# Convex Deployment Configuration
# Get these values from your Convex dashboard or by running `npx convex dev`
CONVEX_DEPLOYMENT=your_deployment_name_here

# Backend URLs
CONVEX_URL=https://your-app.convex.cloud
VITE_CONVEX_URL=https://your-app.convex.cloud
EXPO_PUBLIC_CONVEX_URL=https://your-app.convex.cloud
CONVEX_SITE_URL=https://your-app.convex.site


# Deployment Keys (Used in CI/Vercel)
# CONVEX_DEPLOY_KEY=your_deploy_key_here
