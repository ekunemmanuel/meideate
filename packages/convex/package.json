{
    "name": "@meideate/convex",
    "version": "0.0.0",
    "scripts": {
        "dev": "convex dev",
        "build": "convex codegen || echo 'Convex codegen skipped: Deployment key missing'",
        "deploy": "convex deploy",
        "test": "convex test"
    },
    "private": true,
    "type": "module",
    "dependencies": {
        "convex": "^1.31.7"
    },
    "devDependencies": {
        "@types/node": "^22.13.0"
    },
    "exports": {
        ".": {
            "types": "./src/_generated/api.d.ts",
            "default": "./src/_generated/api.js"
        },
        "./server": {
            "types": "./src/_generated/server.d.ts",
            "default": "./src/_generated/server.js"
        },
        "./dataModel": {
            "types": "./src/_generated/dataModel.d.ts",
            "default": "./src/_generated/dataModel.js"
        },
        "./react": {
            "types": "./src/react.ts",
            "default": "./src/react.ts"
        }
    }
}